<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="nistruct_contentai_report" resource="default" engine="innodb" comment="ContentAI Single Report Table">
        <column xsi:type="int" name="entity_id" nullable="false" identity="true" unsigned="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="entity_type" nullable="false" length="32" default="product" comment="Generated Entity Type"/>
        <column xsi:type="int" name="product_id" nullable="true" unsigned="true" comment="Product ID"/>
        <column xsi:type="varchar" name="product_sku" nullable="true" length="64" comment="Product SKU"/>
        <column xsi:type="int" name="category_id" nullable="true" unsigned="true" comment="Category ID"/>
        <column xsi:type="varchar" name="category_name" nullable="true" length="255" comment="Category Name"/>
        <column xsi:type="int" name="store_id" nullable="true" unsigned="true" comment="Store ID"/>
        <column xsi:type="text" name="generated_content" nullable="true" comment="Generated Content"/>
        <column xsi:type="text" name="ai_description" nullable="true" comment="Legacy Generated Content"/>
        <column xsi:type="text" name="usage_metadata" nullable="true" comment="AI Usage Metadata"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="varchar" name="generator_type" nullable="false" length="16" default="single" comment="Generation Source"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
    </table>
    <table name="nistruct_contentai_bulk_report" resource="default" engine="innodb" comment="ContentAI Bulk Report Table">
        <column xsi:type="int" name="entity_id" nullable="false" identity="true" unsigned="true" comment="Entity ID"/>
        <column xsi:type="int" name="store_id" nullable="true" unsigned="true" comment="Store ID"/>
        <column xsi:type="text" name="ai_data" nullable="true" comment="Generated Bulk Data"/>
        <column xsi:type="text" name="usage_metadata" nullable="true" comment="AI Usage Metadata"/>
        <column xsi:type="varchar" name="approval_status" nullable="false" length="32" default="pending_approval" comment="Approval Status"/>
        <column xsi:type="text" name="applied_fields" nullable="true" comment="Applied Fields"/>
        <column xsi:type="timestamp" name="applied_at" nullable="true" comment="Applied At"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
    </table>
    <table name="nistruct_contentai_seo_report" resource="default" engine="innodb" comment="ContentAI SEO Audit Report Table">
        <column xsi:type="int" name="entity_id" nullable="false" identity="true" unsigned="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="scope" nullable="false" length="32" default="all" comment="Audit Scope"/>
        <column xsi:type="int" name="store_id" nullable="false" unsigned="true" default="0" comment="Store ID"/>
        <column xsi:type="int" name="batch_limit" nullable="false" unsigned="true" default="100" comment="Batch Limit"/>
        <column xsi:type="int" name="batch_offset" nullable="false" unsigned="true" default="0" comment="Batch Offset"/>
        <column xsi:type="int" name="total_available" nullable="false" unsigned="true" default="0" comment="Total Available"/>
        <column xsi:type="smallint" name="has_next_batch" nullable="false" unsigned="true" default="0" comment="Has Next Batch"/>
        <column xsi:type="int" name="total_entities" nullable="false" unsigned="true" default="0" comment="Total Entities"/>
        <column xsi:type="int" name="total_issues" nullable="false" unsigned="true" default="0" comment="Total Issues"/>
        <column xsi:type="int" name="critical_count" nullable="false" unsigned="true" default="0" comment="Critical Issues"/>
        <column xsi:type="int" name="warning_count" nullable="false" unsigned="true" default="0" comment="Warning Issues"/>
        <column xsi:type="int" name="notice_count" nullable="false" unsigned="true" default="0" comment="Notice Issues"/>
        <column xsi:type="text" name="report_data" nullable="true" comment="SEO Audit Report Data"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="NISTRUCT_CONTENTAI_SEO_REPORT_SCOPE_STORE_CREATED" indexType="btree">
            <column name="scope"/>
            <column name="store_id"/>
            <column name="created_at"/>
        </index>
    </table>
</schema>
