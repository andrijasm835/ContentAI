<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <contentai>
            <general>
                <enabled>1</enabled>
                <debug_log>0</debug_log>
            </general>
            <api>
                <provider>openai</provider>
                <openai_model>gpt-5.4-mini</openai_model>
                <openai_max_tokens>1200</openai_max_tokens>
                <openai_input_price>0</openai_input_price>
                <openai_output_price>0</openai_output_price>
                <anthropic_model>claude-sonnet-5</anthropic_model>
                <anthropic_max_tokens>1200</anthropic_max_tokens>
                <anthropic_input_price>0</anthropic_input_price>
                <anthropic_output_price>0</anthropic_output_price>
            </api>
        </contentai>
    </default>
</config>
