<?php /** @var \Nistruct\ContentAI\Block\Adminhtml\Bulk\Form $block */ ?> <style> .contentai-bulk-page { max-width: 1280px; } .contentai-bulk-form { background: #fff; border: 1px solid #d6d6d6; } .contentai-bulk-header { border-bottom: 1px solid #e5e5e5; padding: 18px 22px; } .contentai-bulk-header h2 { font-size: 20px; margin: 0 0 6px; } .contentai-bulk-header p { color: #666; margin: 0; } .contentai-bulk-grid { display: grid; gap: 0; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); } .contentai-bulk-section { padding: 22px; } .contentai-bulk-section + .contentai-bulk-section { border-left: 1px solid #e5e5e5; } .contentai-bulk-section h2 { font-size: 18px; margin: 0 0 18px; } .contentai-bulk-field { margin-bottom: 18px; } .contentai-bulk-field label { display: block; font-weight: 600; margin-bottom: 7px; } .contentai-bulk-field input[type="text"], .contentai-bulk-field input[type="number"], .contentai-bulk-field select, .contentai-bulk-field textarea { max-width: 100%; width: 100%; } .contentai-bulk-field textarea { min-height: 132px; resize: vertical; } .contentai-bulk-category-select { font-family: monospace; min-height: 230px; } .contentai-bulk-checks { display: grid; gap: 8px 18px; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); } .contentai-bulk-checks label { font-weight: 400; margin: 0; } .contentai-bulk-checks input { margin-right: 6px; } .contentai-bulk-note { color: #666; font-size: 12px; line-height: 1.4; margin: 6px 0 0; } .contentai-bulk-actions { border-top: 1px solid #e5e5e5; padding: 18px 22px; text-align: right; } .contentai-bulk-actions .contentai-bulk-running { color: #666; display: none; margin-right: 14px; } .contentai-bulk-form.is-submitting .contentai-bulk-running { display: inline-block; } @media (max-width: 900px) { .contentai-bulk-grid { grid-template-columns: 1fr; } .contentai-bulk-section + .contentai-bulk-section { border-left: 0; border-top: 1px solid #e5e5e5; } }</style><div class="contentai-bulk-page"><form class="contentai-bulk-form" action="<?= $block->escapeUrl($block->getPostUrl()) ?>" method="post" data-contentai-bulk-form><?= $block->getBlockHtml('formkey') ?> <div class="contentai-bulk-header"><h2><?= $block->escapeHtml(__('Bulk Content Generator')) ?></h2><p><?= $block->escapeHtml(__('Select a controlled product batch, choose fields, then review generated results in Bulk Reports before applying anything to products.')) ?></p></div><div class="contentai-bulk-grid"><section class="contentai-bulk-section"><h2><?= $block->escapeHtml(__('Products')) ?></h2><div class="contentai-bulk-field"><label for="contentai_store_id"><?= $block->escapeHtml(__('Store View')) ?></label> <select id="contentai_store_id" name="store_id"><?php foreach ($block->getStoreOptions() as $option): ?> <option value="<?= $block->escapeHtmlAttr((string) $option['value']) ?>"><?= $block->escapeHtml((string) $option['label']) ?></option><?php endforeach; ?></select></div><div class="contentai-bulk-field"><label for="contentai_category_id"><?= $block->escapeHtml(__('Category')) ?></label> <select class="contentai-bulk-category-select" id="contentai_category_id" name="category_id" size="10"><?php foreach ($block->getCategoryOptions() as $option): ?> <option value="<?= $block->escapeHtmlAttr((string) $option['value']) ?>"><?= $block->escapeHtml((string) $option['label']) ?></option><?php endforeach; ?></select> <p class="contentai-bulk-note"><?= $block->escapeHtml(__('Only enabled categories with products in their branch are shown. Product count is displayed in brackets.')) ?></p></div><div class="contentai-bulk-field"><label for="contentai_skus"><?= $block->escapeHtml(__('Specific SKUs')) ?></label> <textarea id="contentai_skus" name="skus" rows="6" placeholder="SKU-1, SKU-2&#10;SKU-3"></textarea> <p class="contentai-bulk-note"><?= $block->escapeHtml(__('Optional. Separate SKUs by comma, space, or new line.')) ?></p></div><div class="contentai-bulk-field"><label for="contentai_limit"><?= $block->escapeHtml(__('Maximum Products')) ?></label> <input id="contentai_limit" name="limit" type="number" min="1" max="50" value="10"/><p class="contentai-bulk-note"><?= $block->escapeHtml(__('Keep batches small enough for review and API cost control.')) ?></p></div></section><section class="contentai-bulk-section"><h2><?= $block->escapeHtml(__('Generation')) ?></h2><div class="contentai-bulk-field"><label><?= $block->escapeHtml(__('Generate Fields')) ?></label> <div class="contentai-bulk-checks"><?php foreach ($block->getFieldOptions() as $code => $label): ?> <label> <input type="checkbox" name="fields[]" value="<?= $block->escapeHtmlAttr($code) ?>" checked/><?= $block->escapeHtml(__($label)) ?></label> <?php endforeach; ?></div></div><div class="contentai-bulk-field"><label><?= $block->escapeHtml(__('Only Products Missing')) ?></label> <div class="contentai-bulk-checks"><?php foreach ($block->getFieldOptions() as $code => $label): ?> <label> <input type="checkbox" name="missing_fields[]" value="<?= $block->escapeHtmlAttr($code) ?>"/><?= $block->escapeHtml(__($label)) ?></label> <?php endforeach; ?></div><p class="contentai-bulk-note"><?= $block->escapeHtml(__('Leave empty to include products even when fields already have values.')) ?></p></div></section></div><div class="contentai-bulk-actions"><span class="contentai-bulk-running"><?= $block->escapeHtml(__('Generation started. Keep this tab open until Bulk Reports loads.')) ?></span> <button type="submit" class="action-primary"><span><?= $block->escapeHtml(__('Start Bulk Generation')) ?></span></button></div></form></div><script>
    require(['jquery'], function ($) {
        $('[data-contentai-bulk-form]').on('submit', function () {
