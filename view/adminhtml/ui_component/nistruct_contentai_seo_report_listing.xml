<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">nistruct_contentai_seo_report_listing.nistruct_contentai_seo_report_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>columns</spinner>
        <deps>
            <dep>nistruct_contentai_seo_report_listing.nistruct_contentai_seo_report_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="nistruct_contentai_seo_report_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Nistruct_ContentAI::seo_report</aclResource>
        <dataProvider class="Nistruct\ContentAI\Ui\DataProvider\SeoReport\DataProvider" name="nistruct_contentai_seo_report_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <sorting>desc</sorting>
                <label translate="true">Report ID</label>
            </settings>
        </column>
        <column name="scope">
            <settings>
                <filter>text</filter>
                <label translate="true">Scope</label>
            </settings>
        </column>
        <column name="store_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Store ID</label>
            </settings>
        </column>
        <column name="total_entities">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Scanned</label>
            </settings>
        </column>
        <column name="total_available">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Available</label>
            </settings>
        </column>
        <column name="batch_offset">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Offset</label>
            </settings>
        </column>
        <column name="batch_limit">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Limit</label>
            </settings>
        </column>
        <column name="total_issues">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Issues</label>
            </settings>
        </column>
        <column name="critical_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Critical</label>
            </settings>
        </column>
        <column name="warning_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Warnings</label>
            </settings>
        </column>
        <column name="notice_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Notices</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Nistruct\ContentAI\Ui\Component\Listing\Column\SeoReportActions">
            <settings>
                <indexField>entity_id</indexField>
                <label translate="true">Actions</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
